                  <p style={{ fontSize: 14, color: 'var(--text-secondary)', lineHeight: 1.7, maxWidth: 580, marginBottom: 16 }}>{layer.body}</p>
                  <div style={{ display: 'flex', gap: 8, flexWrap: 'wrap' }}>
                    {layer.modules.map((m, j) => (
                      <span key={j} style={{
                        fontSize: 11, color: 'var(--text-muted)',
