          section > div > div:last-child > div { grid-template-columns: repeat(3, 1fr) !important; }
        }
        @media (max-width: 600px) {
          section > div > div:last-child > div { grid-template-columns: repeat(2, 1fr) !important; }
        }
      `}</style>
    </section>
  )
}
</file>

