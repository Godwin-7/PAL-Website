                <div style={{ display: 'flex', flexDirection: 'column', gap: 8, flexShrink: 0 }}>
                  {layer.tags.map((t, j) => (
                    <Tag key={j} color={layer.color}>{t}</Tag>
                  ))}
                </div>
              </motion.div>
            </FadeInUp>
          ))}
        </div>
      </div>

      <style>{`
        @media (max-width: 900px) {
          #intelligence .layer-row { grid-template-columns: 1fr !important; gap: 20px !important; }
        }
      `}</style>
    </section>
  )
}
